{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
