{
  "name": "@valet/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/bin.ts",
    "workflow": "bun run src/workflow-cli.ts",
    "build": "bun build src/bin.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && pnpm test:workflows",
    "test:workflows": "bun test src/workflow-compiler.test.ts src/workflow-engine.test.ts src/workflow-cli.test.ts"
  },
  "dependencies": {
    "@1password/sdk": "^0.3.1",
    "@llamaindex/liteparse": "^1.1.0",
    "@valet/shared": "workspace:*",
    "diff": "^8.0.3",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
