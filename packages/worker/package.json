{
  "name": "@valet/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-registry": "bun scripts/generate-plugin-registry.ts",
    "predev": "bun scripts/generate-plugin-registry.ts",
    "dev": "wrangler dev",
    "prebuild": "bun scripts/generate-plugin-registry.ts",
    "build": "wrangler deploy --dry-run",
    "predeploy": "bun scripts/generate-plugin-registry.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply valet-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply valet-db --remote",
    "db:seed": "wrangler d1 execute valet-db --local --file=scripts/seed-test-data.sql",
    "test": "vitest run"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.3",
    "@cf-wasm/satori": "^0.3.3",
    "@hono/zod-validator": "^0.2.1",
    "@valet/plugin-cloudflare": "workspace:*",
    "@valet/plugin-deepwiki": "workspace:*",
    "@valet/plugin-email-auth": "workspace:*",
    "@valet/plugin-figma": "workspace:*",
    "@valet/plugin-github": "workspace:*",
    "@valet/plugin-gmail": "workspace:*",
    "@valet/plugin-google-auth": "workspace:*",
    "@valet/plugin-google-calendar": "workspace:*",
    "@valet/plugin-google-workspace": "workspace:*",
    "@valet/plugin-linear": "workspace:*",
    "@valet/plugin-notion": "workspace:*",
    "@valet/plugin-sentry": "workspace:*",
    "@valet/plugin-slack": "workspace:*",
    "@valet/plugin-stripe": "workspace:*",
    "@valet/plugin-telegram": "workspace:*",
    "@valet/plugin-typefully": "workspace:*",
    "@valet/sdk": "workspace:*",
    "@valet/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.3.0",
    "octokit": "^5.0.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/better-sqlite3": "^7.6.8",
    "better-sqlite3": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18",
    "wrangler": "^3.28.0"
  }
}
