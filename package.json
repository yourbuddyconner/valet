{
  "name": "valet",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @valet/worker dev",
    "build": "pnpm --filter @valet/worker build",
    "deploy": "pnpm --filter @valet/worker deploy",
    "db:migrate": "pnpm --filter @valet/worker db:migrate",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.1",
      "defu": "^6.1.5",
      "lodash-es": "^4.18.1",
      "picomatch@2": "2.3.2",
      "rollup": "^4.61.0"
    }
  }
}
