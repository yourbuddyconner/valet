{
  "name": "valet",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @valet/api dev",
    "build": "pnpm --filter @valet/api build",
    "deploy": "pnpm --filter @valet/api deploy",
    "db:migrate": "pnpm --filter @valet/api db:migrate",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
