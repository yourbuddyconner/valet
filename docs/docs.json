{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Valet",
  "description": "Product documentation for Valet, an AI coworker with its own workspace, memory, connected tools, channels, workflows, and approvals.",
  "colors": {
    "primary": "#1747E6",
    "light": "#5B7FF5",
    "dark": "#0E2DB3"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "logo": {
    "light": "/logo/valet-light.svg",
    "dark": "/logo/valet-dark.svg",
    "href": "/"
  },
  "favicon": "/logo/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "Use cases",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "use-cases/overview"
            ]
          },
          {
            "group": "By team",
            "pages": [
              "use-cases/software-engineering",
              "use-cases/operations",
              "use-cases/customer-workflows"
            ]
          }
        ]
      },
      {
        "tab": "Product docs",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "product/what-is-valet",
              "product/quickstart",
