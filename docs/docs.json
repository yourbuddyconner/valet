{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Valet",
  "description": "Product documentation for Valet, an AI coworker with its own hosted workstation, persistent memory, channels, integrations, workflows, policies, and technical execution environment.",
  "colors": {
    "primary": "#1747E6",
    "light": "#5B7FF5",
    "dark": "#0E2DB3"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "logo": {
    "light": "/logo/valet-light.svg",
    "dark": "/logo/valet-dark.svg",
    "href": "/"
  },
  "favicon": "/logo/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "Use cases",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "use-cases/overview"
            ]
          },
          {
            "group": "By team",
            "pages": [
              "use-cases/software-engineering",
              "use-cases/operations",
              "use-cases/customer-workflows"
            ]
          }
        ]
      },
      {
        "tab": "Product docs",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "product/what-is-valet",
              "product/quickstart",
              "product/how-valet-works"
            ]
          },
          {
            "group": "Everyday use",
            "pages": [
              "product/sessions",
              "product/workstations-and-sandboxes",
              "product/triggers-and-workflows",
              "product/orchestrators-and-memory",
              "product/skills-and-personas"
            ]
          },
          {
            "group": "Trust and control",
            "pages": [
              "product/auth-and-access",
              "product/policies-and-approvals",
              "product/channels",
              "product/integrations",
              "product/admin-setup"
            ]
          }
        ]
      },
      {
        "tab": "Engineering",
        "groups": [
          {
            "group": "System internals",
            "pages": [
              "architecture",
              "engineering/session-lifecycle",
              "engineering/sandbox-lifecycle",
              "engineering/runner-and-opencode",
              "engineering/real-time-streaming",
              "engineering/workflow-execution",
              "engineering/orchestrator-runtime",
              "engineering/plugin-system",
              "engineering/policy-engine",
              "engineering/auth-access-internals"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "security-model",
              "deployment",
              "environment-variables",
              "project-structure"
            ]
          },
          {
            "group": "Setup",
            "pages": [
              "oauth-setup",
              "slack-setup"
            ]
          },
          {
            "group": "Docs system",
            "pages": [
              "product/design-language",
              "product/character-assets"
            ]
          }
        ]
      },
      {
        "tab": "API & MCP",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api-reference",
              "product/mcp-endpoint"
            ]
          }
        ]
      }
    ]
  },
  "seo": {
    "indexing": "navigable"
  },
  "search": {
    "prompt": "Search Valet docs for product concepts, use cases, sessions, workspaces, workflows, approvals, channels, integrations, engineering internals, API routes, and MCP access."
  }
}
