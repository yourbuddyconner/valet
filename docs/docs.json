        "groups": [
          {
            "group": "Agent access",
            "pages": [
              "product/mcp-endpoint",
              "api-reference"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture",
              "security-model",
              "deployment",
              "environment-variables",
              "project-structure"
            ]
          },
          {
            "group": "Setup",
            "pages": [
              "oauth-setup",
              "slack-setup"
            ]
          }
        ]
